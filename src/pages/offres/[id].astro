---
import { getOffre } from "../../backend.mjs";
import Layout from "../../layouts/Layout.astro";
import PbImage from "../../components/PbImage.astro";

const { id } = Astro.params;
const offre = await getOffre(id);

const firstImage = offre?.image?.[0];
---

<Layout titre={offre?.nom_maison ?? "Offre introuvable"}>
    {
        offre ? (
            <section class="max-w-6xl mx-auto mt-8">
                <div class="bg-white rounded-3xl shadow-lg overflow-hidden">
                    <div class="grid lg:grid-cols-2">
                        <div class="bg-gray-100 p-4 flex items-center justify-center min-h-[420px]">
                            {firstImage ? (
                                <PbImage
                                    record={offre}
                                    image={firstImage}
                                    width={900}
                                    height={600}
                                    fit="contain"
                                />
                            ) : (
                                <p class="text-red-600">Aucune image trouvée</p>
                            )}
                        </div>

                        <div class="p-8 lg:p-10 flex flex-col justify-between">
                            <div>
                                <p class="text-sm uppercase tracking-wide text-gray-500 mb-2">
                                    Détail de l’offre
                                </p>

                                <h1 class="text-4xl font-extrabold text-slate-900 mb-4">
                                    {offre.nom_maison}
                                </h1>

                                <p class="text-lg text-gray-600 mb-6">
                                    {offre.nombre_chambre} chambres •
                                    {offre.nombre_salle_de_bain} salles de bain
                                    •{offre.surface} m²
                                </p>

                                <div class="text-4xl font-bold text-blue-600 mb-8">
                                    {offre.prix} €
                                </div>

                                <div class="grid sm:grid-cols-2 gap-4 mb-8">
                                    <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
                                        <p class="text-sm text-gray-500 mb-1">
                                            Adresse
                                        </p>
                                        <p class="font-semibold text-slate-800">
                                            {offre.adresse_complete ||
                                                "Non renseignée"}
                                        </p>
                                    </div>

                                    <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
                                        <p class="text-sm text-gray-500 mb-1">
                                            Surface
                                        </p>
                                        <p class="font-semibold text-slate-800">
                                            {offre.surface} m²
                                        </p>
                                    </div>

                                    <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
                                        <p class="text-sm text-gray-500 mb-1">
                                            Chambres
                                        </p>
                                        <p class="font-semibold text-slate-800">
                                            {offre.nombre_chambre}
                                        </p>
                                    </div>

                                    <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
                                        <p class="text-sm text-gray-500 mb-1">
                                            Salles de bain
                                        </p>
                                        <p class="font-semibold text-slate-800">
                                            {offre.nombre_salle_de_bain}
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="flex flex-wrap gap-3">
                                <a href="/offres" class="btn-primary">
                                    Retour aux offres
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        ) : (
            <p class="mt-6 text-red-600">Offre introuvable</p>
        )
    }
</Layout>
