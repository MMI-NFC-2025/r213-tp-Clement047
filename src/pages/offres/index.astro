---
import Layout from "../../layouts/Layout.astro";
import OffreCard from "../../components/OffreCard.astro";
import { getOffres, filterByPrix } from "../../backend.mjs";

let message = "";
let offres = [];

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const minPrix = parseInt(data.get("minPrix"));
  const maxPrix = parseInt(data.get("maxPrix"));

  if (
    !Number.isNaN(minPrix) &&
    !Number.isNaN(maxPrix) &&
    minPrix >= 0 &&
    maxPrix >= minPrix
  ) {
    offres = await filterByPrix(minPrix, maxPrix);
    message =
      offres.length === 0
        ? `Pas d'offres entre ${minPrix}€ et ${maxPrix}€`
        : `Liste des offres entre ${minPrix}€ et ${maxPrix}€`;
  } else {
    message = "Veuillez entrer des valeurs valides.";
    offres = await getOffres();
  }
} else {
  offres = await getOffres();
}
---

<Layout titre="Offres">
  <h1 class="text-2xl font-bold mb-4">Offres</h1>

  <!-- 🔎 FILTRE PRIX -->
  <form
    action="/offres"
    method="POST"
    class="flex gap-3 flex-wrap items-center mb-6"
  >
    <input
      type="number"
      name="minPrix"
      placeholder="Prix minimum"
      class="p-2 border rounded-md"
      min="0"
    />
    <input
      type="number"
      name="maxPrix"
      placeholder="Prix maximum"
      class="p-2 border rounded-md"
      min="0"
    />
    <button type="submit" class="btn-primary"> Filtrer par prix </button>
  </form>

  {message && <p class="mb-4 text-gray-600">{message}</p>}

  <!-- Navigation secondaire -->
  <div class="flex gap-3 flex-wrap items-center mb-6">
    <a href="/offres/surface/80" class="btn-primary"> Maisons > 80 m² </a>

    <a href="/offres/prix/3000" class="btn-primary"> Moins de 3000 € </a>

    <a href="/offres/favoris" class="btn-primary"> Favoris </a>
  </div>

  <!-- Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {offres.map((offre) => <OffreCard offre={offre} />)}
  </div>
</Layout>
