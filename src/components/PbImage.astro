---
import { getImageUrl } from "../backend.mjs";

const { record, image, width = 600, height = 300, fit = "cover" } = Astro.props;

const imageURL = getImageUrl(record, image);
---

{
    imageURL ? (
        <img
            src={imageURL}
            alt={`Photo de ${record.nom_maison ?? "maison"}`}
            width={width}
            height={height}
            class={`w-full rounded-lg mb-3 ${fit === "contain" ? "object-contain" : "object-cover"} ${fit === "contain" ? "" : "h-48"}`}
        />
    ) : (
        <p style="color:#b91c1c;">Aucune image trouvée</p>
    )
}
